# DeepSeek / OpenAI 兼容聊天模型配置
# 聊天模型 API Key，用于 Agent 对话、规划、执行等 LLM 调用。
DEEPSEEK_API_KEY=
# 聊天模型 OpenAI 兼容接口地址；DeepSeek 默认是 https://api.deepseek.com。
DEEPSEEK_BASE_URL=https://api.deepseek.com
# 聊天模型名称；也兼容旧变量 MODEL_NAME，但优先使用 DEEPSEEK_MODEL。
DEEPSEEK_MODEL=deepseek-v4-flash
# 聊天模型温度，0 表示输出更稳定。
MODEL_TEMPERATURE=0

# 后端服务配置
# Hono 后端监听端口；如果前端代理到 3210，这里设置为 3210。
PORT=3000
# 允许访问后端的前端地址，当前主要用于 CORS/部署约定。
WEB_ORIGIN=http://localhost:5173

# Agent Loop 安全上限
# Agent 节点失败后的最大重试次数；不包含第一次执行。
MAX_AGENT_RETRIES=2
# 单轮 Agent 运行中最多允许调用工具的次数，防止工具循环失控。
MAX_TOOL_CALLS=8

# Tool / Skill 白名单配置
# 逗号分隔的 Tool 白名单；留空表示启用所有已注册 Tool。
ENABLED_TOOLS=
# 逗号分隔的 Skill 白名单；留空表示启用所有已注册 Skill。
# ENABLED_SKILLS 会影响 Router 可选 Skill、Agent 注入和 GET /skills 的 enabled 字段。
ENABLED_SKILLS=

# PostgreSQL / pgvector 数据库配置
# PostgreSQL 连接字符串；需要目标数据库已安装并启用 pgvector 扩展。
DATABASE_URL=postgresql://用户名:密码@localhost:5432/agent4

# Embedding 向量模型配置
# Embedding API Key；用于“文本 -> 向量”。如果留空，会回退使用 DEEPSEEK_API_KEY。
EMBEDDING_API_KEY=
# Embedding OpenAI 兼容接口地址。如果留空，会回退使用 DEEPSEEK_BASE_URL。
# 例如 DashScope: https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_BASE_URL=
# Embedding 模型名称；必须是 EMBEDDING_BASE_URL 对应服务真实支持的模型。
EMBEDDING_MODEL=text-embedding-v3
# Embedding 向量维度；必须和数据库 schema.sql 中 vector(2048) 的维度一致。
EMBEDDING_DIM=2048
# 自动知识库模式的 pgvector 距离阈值；越小越严格，默认 0.55。
AUTO_RAG_DISTANCE_THRESHOLD=0.55

# 知识库上传配置
# 上传文件保存目录；相对路径会相对于后端启动目录解析。
UPLOAD_DIR=uploads

# JWT 登录认证配置
# JWT 签名密钥；生产环境请换成足够长的随机字符串，不能提交真实密钥。
JWT_SECRET=请换成一个足够长的随机字符串
# JWT 过期时间，例如 7d、24h、60m。
JWT_EXPIRES_IN=7d
